{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/analyze.js": {
      "maxDuration": 300
    },
    "api/generate-report.js": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
